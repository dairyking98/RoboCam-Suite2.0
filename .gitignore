# =============================================================================
# RoboCam-Suite 2.0 — .gitignore
# =============================================================================

# Virtual environment directories (any name is covered)
.venv/
venv/
env/
ENV/
.env/

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# PyInstaller
*.spec
dist/
build/

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# Editors and IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# Experiment outputs (large data files — keep structure, not data)
outputs/
/experiments/

# Logs
*.log
logs/

# Config overrides (user-specific, never commit)
robocam_suite/config/local_config.json
