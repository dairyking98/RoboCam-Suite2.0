{
    "motion_controller": {
        "driver": "gcode_serial",
        "port": "auto",
        "baudrate": 115200,
        "timeout": 1.0,
        "home_timeout": 90.0,
        "movement_wait_timeout": 30.0
    },
    "camera": {
        "driver": "opencv",
        "camera_index": 0,
        "resolution": [1920, 1080],
        "fps": 30.0
    },
    "gpio_controller": {
        "driver": "arduino_serial",
        "port": "auto",
        "baudrate": 9600,
        "timeout": 1.0
    },
    "simulation": {
        "motion_controller": false,
        "camera": false,
        "gpio_controller": false
    }
}
